{
  "name": "pathwise",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "build:web": "tsc -b packages/types packages/engine && npx next build apps/web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc -b",
    "test": "npm exec -w @pathwise/engine -- vitest run",
    "test:e2e": "playwright test",
    "ci:prisma:generate": "npm --workspace @pathwise/api run prisma:generate",
    "db:up": "docker compose -f infra/compose/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/compose/docker-compose.yml down",
    "dev:api": "npm run dev -w @pathwise/api",
    "dev:web": "npm run dev -w @pathwise/web",
    "db:seed": "npm --workspace @pathwise/api run seed",
    "pretest:e2e": "node scripts/check-db.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "prisma": "^6.19.2",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@nestjs/schedule": "^6.1.1",
    "@prisma/client": "^6.19.2",
    "zod": "^4.3.6"
  }
}
