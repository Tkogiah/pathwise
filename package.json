{
  "name": "pathwise",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc -b",
    "test": "npm exec -w @pathwise/engine -- vitest run",
    "db:up": "docker compose -f infra/compose/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/compose/docker-compose.yml down",
    "dev:api": "npm run dev -w @pathwise/api",
    "dev:web": "npm run dev -w @pathwise/web",
    "db:seed": "npm --workspace @pathwise/api run seed"
  },
  "devDependencies": {
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.18"
  }
}
