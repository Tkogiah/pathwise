generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum UserRole {
  CASE_MANAGER
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  COMPLETE
}

enum BlockerType {
  INTERNAL
  EXTERNAL
  UNKNOWN
}

enum NoteLabel {
  APPOINTMENT
  DOCUMENTS
  HOUSING_SEARCH
  VOUCHER
  BENEFITS
  OUTREACH
  ID_VERIFICATION
  BARRIER
  TASK_UPDATE
  OTHER
}

enum ExtractionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EvidenceSource {
  SLACK
}

// --- Users & Clients ---

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String?
  role         UserRole @default(CASE_MANAGER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  taskInstances TaskInstance[]
  digests       UserDigest[]
}

model UserDigest {
  id        String    @id @default(cuid())
  userId    String
  dateKey   String
  summary   String
  emailedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, dateKey])
}

model Client {
  id         String   @id @default(cuid())
  firstName  String
  lastName   String
  externalId String?
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  programInstances ClientProgramInstance[]
  extractions      Extraction[]
  facts            Fact[]
}

// --- Templates (immutable blueprints) ---

model ProgramTemplate {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stages           TemplateStage[]
  programInstances ClientProgramInstance[]
  extractions      Extraction[]
}

model TemplateStage {
  id                     String  @id @default(cuid())
  templateId             String
  title                  String
  orderIndex             Int
  iconName               String
  recommendedDurationDays Int?
  timelineLabel           String?

  template       ProgramTemplate @relation(fields: [templateId], references: [id])
  tasks          TemplateTask[]
  stageInstances StageInstance[]
  facts          Fact[]
}

model TemplateTask {
  id              String  @id @default(cuid())
  stageId         String
  title           String
  description     String?
  isRequired      Boolean @default(true)
  dependsOnTaskId String?
  orderIndex      Int
  dueOffsetDays   Int?

  stage         TemplateStage  @relation(fields: [stageId], references: [id])
  dependsOnTask TemplateTask?  @relation("TaskDependency", fields: [dependsOnTaskId], references: [id])
  dependentTasks TemplateTask[] @relation("TaskDependency")
  taskInstances TaskInstance[]
  facts         Fact[]
}

// --- Instances (per-client runtime data) ---

model ClientProgramInstance {
  id         String   @id @default(cuid())
  clientId   String
  templateId String
  startDate         DateTime
  programLengthDays Int?
  isActive          Boolean  @default(true)
  overviewSummary   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  client         Client          @relation(fields: [clientId], references: [id])
  template       ProgramTemplate @relation(fields: [templateId], references: [id])
  stageInstances StageInstance[]
}

model StageInstance {
  id                String    @id @default(cuid())
  programInstanceId String
  templateStageId   String
  activatedAt       DateTime?
  completedAt       DateTime?
  handoffSummary    String?

  programInstance ClientProgramInstance @relation(fields: [programInstanceId], references: [id])
  templateStage   TemplateStage         @relation(fields: [templateStageId], references: [id])
  taskInstances   TaskInstance[]
}

model TaskInstance {
  id              String      @id @default(cuid())
  stageInstanceId String
  templateTaskId  String
  status          TaskStatus  @default(NOT_STARTED)
  assignedUserId  String?
  dueDate         DateTime?
  dueNote         String?
  appointmentAt   DateTime?
  appointmentNote String?
  blockerType     BlockerType?
  blockerNote     String?
  completedAt     DateTime?
  isNa            Boolean     @default(false)
  naReason        String?

  stageInstance StageInstance @relation(fields: [stageInstanceId], references: [id])
  templateTask  TemplateTask  @relation(fields: [templateTaskId], references: [id])
  assignedUser  User?         @relation(fields: [assignedUserId], references: [id])
  notes         TaskNote[]
}

model TaskNote {
  id             String    @id @default(cuid())
  taskInstanceId String
  authorId       String
  label          NoteLabel @default(OTHER)
  summary        String?
  body           String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  taskInstance TaskInstance @relation(fields: [taskInstanceId], references: [id])
}

// --- AI Ingestion ---

model Extraction {
  id                String           @id @default(cuid())
  programId         String
  clientId          String?
  clientRef         String
  rawText           String
  structuredPayload Json
  confidence        Float
  status            ExtractionStatus @default(PENDING)
  requiresReview    Boolean          @default(true)
  createdAt         DateTime         @default(now())
  approvedAt        DateTime?
  rejectedAt        DateTime?

  program  ProgramTemplate @relation(fields: [programId], references: [id])
  client   Client?         @relation(fields: [clientId], references: [id])
  evidence Evidence[]
  facts    Fact[]
}

model Evidence {
  id           String         @id @default(cuid())
  extractionId String
  source       EvidenceSource @default(SLACK)
  permalink    String
  author       String
  timestamp    DateTime
  createdAt    DateTime       @default(now())

  extraction Extraction @relation(fields: [extractionId], references: [id])
}

model Fact {
  id           String    @id @default(cuid())
  extractionId String
  clientId     String
  stageId      String?
  taskId       String?
  statusValue  String?
  notes        String?
  source       String    @default("slack")
  createdAt    DateTime  @default(now())

  extraction    Extraction     @relation(fields: [extractionId], references: [id])
  client        Client         @relation(fields: [clientId], references: [id])
  templateStage TemplateStage? @relation(fields: [stageId], references: [id])
  templateTask  TemplateTask?  @relation(fields: [taskId], references: [id])
}
